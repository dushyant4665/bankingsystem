# Server
PORT=5000
NODE_ENV=development

# Database
DATABASE_URL="postgresql://postgres:your_password@localhost:5432/banking_db"
# Docker Compose overrides DATABASE_URL inside the container to:
# postgresql://postgres:postgres@db:5432/banking?schema=public

# JWT
JWT_SECRET="your-super-secret-jwt-key-minimum-32-chars"
JWT_EXPIRES_IN="7d"
ADMIN_EMAIL="admin@example.com"

# Bcrypt
BCRYPT_ROUNDS=10

# Redis
REDIS_URL="redis://localhost:6379"

# OpenAI (Optional - fraud detection ke liye)
OPENAI_API_KEY="your-openai-api-key"
